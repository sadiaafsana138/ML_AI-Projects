  {"cell_type": "markdown", "metadata": {}, "source": ["---\n", "## 24. VIEWS vs COPIES"]},
  {
   "cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": [
    "# CRITICAL to understand for memory bugs\n",
    "\n",
    "arr = np.array([1, 2, 3, 4, 5])\n",
    "\n",
    "# View — shares memory (modifying one changes the other)\n",
    "view = arr[1:4]         # slices are views!\n",
    "view[0] = 99\n",
    "print(arr)              # arr is also changed!\n",
    "\n",
    "# Copy — independent\n",
    "copy = arr[1:4].copy()\n",
    "copy[0] = 0\n",
    "print(arr)              # arr unchanged\n",
    "\n",
    "# Check if it's a view\n",
    "print(view.base is arr)   # True = view\n",
    "print(copy.base is arr)   # False = copy\n",
    "\n",
    "# ravel returns view when possible, flatten always copies\n",
    "arr2d = arr.reshape(1, 5)\n",
    "r = arr2d.ravel()       # may be view\n",
    "f = arr2d.flatten()     # always copy"
   ]
  },

  {"cell_type": "markdown", "metadata": {}, "source": ["---\n", "## 25. MEMORY & PERFORMANCE"]},
  {
   "cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": [
    "arr = np.arange(1_000_000)\n",
    "\n",
    "print(arr.nbytes)       # total bytes\n",
    "print(arr.itemsize)     # bytes per element\n",
    "print(arr.strides)      # step in bytes per axis\n",
    "\n",
    "# Use float32 instead of float64 to halve memory\n",
    "arr32 = arr.astype(np.float32)\n",
    "print(arr32.nbytes)\n",
    "\n",
    "# Vectorization is always faster than Python loops\n",
    "import time\n",
    "\n",
    "# Slow (Python loop)\n",
    "t = time.time()\n",
    "res = [x * 2 for x in arr]\n",
    "print('loop:', time.time() - t)\n",
    "\n",
    "# Fast (NumPy vectorized)\n",
    "t = time.time()\n",
    "res = arr * 2\n",
    "print('numpy:', time.time() - t)\n",
    "\n",
    "# Use out= param to avoid creating new array\n",
    "out = np.empty_like(arr)\n",
    "np.multiply(arr, 2, out=out)   # write result directly to out\n",
    "\n",
    "# Contiguous memory (C-order vs Fortran-order)\n",
    "arr_c = np.ascontiguousarray(arr)    # row-major (default)\n",
    "arr_f = np.asfortranarray(arr)       # column-major (better for BLAS ops)\n",
    "arr.flags"
   ]
  },

  {"cell_type": "markdown", "metadata": {}, "source": ["---\n", "## 26. USEFUL UTILITY FUNCTIONS"]},
  {
   "cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": [
    "# Diagonal\n",
    "mat = np.arange(9).reshape(3,3)\n",
    "np.diag(mat)           # extract diagonal → 1D\n",
    "np.diag([1,2,3])       # create diagonal matrix from 1D\n",
    "np.diagflat([1,2,3])   # same but with offset option\n",
    "np.triu(mat)           # upper triangle\n",
    "np.tril(mat)           # lower triangle\n",
    "\n",
    "# Flip\n",
    "np.flip(mat)           # flip all axes\n",
    "np.flip(mat, axis=0)   # flip rows (up-down)\n",
    "np.flip(mat, axis=1)   # flip cols (left-right)\n",
    "np.fliplr(mat)         # flip left-right\n",
    "np.flipud(mat)         # flip up-down\n",
    "np.rot90(mat)          # rotate 90 degrees\n",
    "np.rot90(mat, k=2)     # rotate 180 degrees\n",
    "\n",
    "# Roll (circular shift)\n",
    "arr = np.array([1,2,3,4,5])\n",
    "np.roll(arr, 2)        # [4,5,1,2,3]\n",
    "np.roll(arr, -1)       # [2,3,4,5,1]\n",
    "\n",
    "# Piecewise function\n",
    "x = np.array([-3, -1, 0, 1, 3])\n",
    "np.piecewise(x,\n",
    "    [x < 0, x == 0, x > 0],\n",
    "    [lambda x: x*2, 0, lambda x: x**2])\n",
    "\n",
    "# Bincount (fast frequency count for non-neg ints)\n",
    "arr = np.array([1,0,2,1,1,3,2])\n",
    "np.bincount(arr)       # [1,3,2,1] — count each value 0..max"
   ]
  },

