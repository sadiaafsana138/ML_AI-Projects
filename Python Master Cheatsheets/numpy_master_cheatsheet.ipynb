    "\n",
    "# Polynomial fit\n",
    "x = np.array([0, 1, 2, 3, 4])\n",
    "y = np.array([1, 3, 7, 13, 21])\n",
    "coeffs = np.polyfit(x, y, deg=2)   # fit degree-2 polynomial\n",
    "np.polyval(coeffs, x)              # evaluate fitted polynomial"
   ]
